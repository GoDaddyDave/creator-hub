---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Dave Digital Creative</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: #050505;
        color: white;
        font-family: Inter, sans-serif;
      }

      a {
        color: inherit;
      }

      .hero {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .hero video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.24;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at center, rgba(255, 255, 255, 0.08), transparent 35%),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.35), rgba(5, 5, 5, 0.98));
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 1060px;
        padding: 2rem;
        margin: 0 auto;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 1rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #d0d0d0;
      }

      h1 {
        margin: 0 0 1.5rem;
        font-size: clamp(3rem, 7vw, 6.8rem);
        line-height: 0.92;
        letter-spacing: -0.07em;
        text-align: center;
      }

      .hero p {
        max-width: 760px;
        margin: 0 auto;
        color: #d0d0d0;
        font-size: clamp(1.05rem, 2vw, 1.3rem);
        line-height: 1.7;
        text-align: center;
      }

      .buttons {
        margin-top: 2.4rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .button {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 800;
        transition: 0.25s ease;
      }

      .primary {
        background: white;
        color: black;
      }

      .secondary {
        border: 1px solid #444;
        background: rgba(255, 255, 255, 0.04);
      }

      .button:hover {
        transform: translateY(-3px);
      }

      .section {
        width: min(1180px, calc(100% - 2rem));
        margin: auto;
        padding: 6rem 0;
      }

      .section-header {
        max-width: 850px;
        margin: 0 auto 3rem;
        text-align: center;
      }

      h2 {
        margin: 0 0 1rem;
        font-size: clamp(2.35rem, 5vw, 4.1rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
        text-align: center;
      }

      .section-header p {
        max-width: 760px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.7;
        font-size: 1.08rem;
        text-align: center;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.15rem;
      }

      .card {
        background: linear-gradient(180deg, #121212, #0c0c0c);
        border: 1px solid #222;
        border-radius: 24px;
        padding: 1.65rem;
        transition: 0.25s ease;
        text-align: center;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: #555;
      }

      .card h3 {
        margin: 0 0 0.75rem;
        font-size: 1.25rem;
      }

      .card p {
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.65;
        font-size: 0.98rem;
      }

      .media-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1.25rem;
      }

      .media-card {
        grid-column: span 6;
        overflow: hidden;
        background: linear-gradient(180deg, #121212, #0b0b0b);
        border-radius: 24px;
        border: 1px solid #222;
      }

      .media-card.large {
        grid-column: span 12;
      }

      .media-card img,
      .media-card video {
        width: 100%;
        height: 260px;
        display: block;
        object-fit: cover;
        background: #090909;
      }

      .media-card.large video {
        height: 420px;
      }

      .media-copy {
        padding: 1.35rem;
        text-align: center;
      }

      .media-copy h3 {
        margin: 0 0 0.55rem;
        font-size: 1.28rem;
      }

      .media-copy p {
        max-width: 680px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.65;
        font-size: 0.98rem;
      }

      .pricing {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(285px, 1fr));
        gap: 1.25rem;
      }

      .price-card {
        position: relative;
        background: linear-gradient(180deg, #121212, #0b0b0b);
        border: 1px solid #222;
        border-radius: 24px;
        padding: 1.75rem;
        text-align: center;
      }

      .popular {
        border-color: #666;
        transform: scale(1.02);
      }

      .popular-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: white;
        color: black;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 800;
      }

      .price-card h3 {
        margin: 0;
        font-size: 1.45rem;
      }

      .price {
        margin: 0.8rem 0 1rem;
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
      }

      .price-card ul {
        display: inline-block;
        margin: 0 auto;
        padding-left: 1.2rem;
        color: #bdbdbd;
        line-height: 1.85;
        text-align: left;
      }

      .contact {
        text-align: center;
        padding-bottom: 7rem;
      }

      .contact-links {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .contact-links a {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        border: 1px solid #333;
        text-decoration: none;
        font-weight: 700;
        transition: 0.25s ease;
      }

      .contact-links a:hover {
        transform: translateY(-3px);
        border-color: #777;
      }

      footer {
        border-top: 1px solid #1a1a1a;
        padding: 2rem;
        text-align: center;
        color: #666;
        font-size: 0.9rem;
      }

      @media (max-width: 780px) {
        .section {
          padding: 4.75rem 0;
        }

        .media-card,
        .media-card.large {
          grid-column: span 12;
        }

        .media-card img,
        .media-card video,
        .media-card.large video {
          height: 240px;
        }

        .popular {
          transform: none;
        }
      }
    </style>
  </head>

  <body>
    <section class="hero">
      <video autoplay muted loop playsinline>
        <source src="/videos/reel.mp4" type="video/mp4" />
      </video>

      <div class="hero-content">
        <div class="eyebrow">Cinematic AI Commercial Creative</div>

        <h1>AI Video Commercials for Brands</h1>

        <p>
          Monthly retainer-based cinematic ad creative for businesses running
          paid social. Fresh 15–30 second video spots every month — no
          production team required.
        </p>

        <div class="buttons">
          <a href="#work" class="button primary">View Work</a>
          <a href="#contact" class="button secondary">Book A Call</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>What I Build</h2>

        <p>
          Cinematic AI commercial creative for brands running paid social ads
          across Facebook, Instagram, YouTube, and short-form platforms.
        </p>
      </div>

      <div class="grid">
        <div class="card">
          <h3>AI Video Commercials</h3>

          <p>
            Monthly ad creative for businesses running Facebook, Instagram,
            and YouTube ads. Fresh 15s and 30s cinematic spots — custom to
            your brand, delivered monthly.
          </p>
        </div>

        <div class="card">
          <h3>Spec Ad Previews</h3>

          <p>
            Not sure what you'd get? I build a real 15-second spec ad for
            your brand before you commit to anything. See the work first.
          </p>
        </div>

        <div class="card">
          <h3>Sonic Branding</h3>

          <p>
            Custom music and sound identity for brands that want a complete
            audio-visual package.
          </p>
        </div>
      </div>
    </section>

    <section id="work" class="section">
      <div class="section-header">
        <h2>Featured Work</h2>

        <p>
          Real spec ads and commercial creative built for Houston-area
          businesses and creator brands.
        </p>
      </div>

      <div class="media-grid">
        <div class="media-card">
          <img src="/images/notebooklm.png" alt="Milk and Honey Spa Spec Ad" />

          <div class="media-copy">
            <h3>Milk + Honey Spa — Spec Ad</h3>

            <p>
              Custom 15-second cinematic spec ad built for Milk + Honey Houston.
              Character-consistent AI video with branded ingredient, voiceover,
              and membership offer.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/banners.png" alt="SkinSpirit Spec Ad" />

          <div class="media-copy">
            <h3>SkinSpirit — Spec Ad</h3>

            <p>
              15-second cinematic spec ad for SkinSpirit Rice Village.
              Built from brand photography ingredients in Google Flow / Veo 3.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/dashboard.png" alt="Livestream dashboard" />

          <div class="media-copy">
            <h3>Livestream Dashboard</h3>

            <p>
              Supporting portfolio work showcasing branded visual systems,
              recurring production layouts, and organized broadcast flow.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/sonic-branding.png" alt="Sonic branding assets" />

          <div class="media-copy">
            <h3>Sonic Branding</h3>

            <p>
              Custom songs, branded sound identity, and recurring audio systems
              developed across multiple creator and business ecosystems.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Monthly Retainers</h2>

        <p>
          Built for businesses already spending on ads that need fresh creative
          every month without hiring a production team.
        </p>
      </div>

      <div class="pricing">
        <div class="price-card">
          <h3>Starter</h3>

          <div class="price">$1,000/mo</div>

          <ul>
            <li>2 fresh video ads per month</li>
            <li>15s + 30s formats</li>
            <li>1 revision round each</li>
            <li>Music included</li>
            <li>Delivered by the 10th</li>
            <li>3-month minimum</li>
          </ul>
        </div>

        <div class="price-card popular">
          <div class="popular-badge">Most Popular</div>

          <h3>Growth</h3>

          <div class="price">$2,500/mo</div>

          <ul>
            <li>4 ads per month</li>
            <li>Weekly delivery cadence</li>
            <li>15s, 30s, and social cuts</li>
            <li>2 revision rounds each</li>
            <li>Priority 48-hour turnaround</li>
            <li>Sonic branding included</li>
            <li>3-month minimum</li>
          </ul>
        </div>

        <div class="price-card">
          <h3>Full System</h3>

          <div class="price">$5,000/mo</div>

          <ul>
            <li>Weekly content + strategy</li>
            <li>Full ad creative suite</li>
            <li>Sonic branding identity</li>
            <li>Monthly planning session</li>
            <li>Unlimited minor revisions</li>
            <li>3-month minimum</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="contact" class="section contact">
      <div class="section-header">
        <h2>Let’s Build Something</h2>

        <p>
          Running paid social and want fresh video creative every month
          without hiring a production team? Let's talk.
        </p>
      </div>

      <div class="contact-links">
        <a href="https://x.com/_davedigital" target="_blank">
          X / Twitter
        </a>

        <a href="https://instagram.com/_davedigital" target="_blank">
          Instagram
        </a>

        <a href="mailto:djdjfrosty@gmail.com">
          Email
        </a>
      </div>
    </section>

    <footer>
      Additional creative and creator ecosystem work available upon request.
    </footer>
  </body>
</html>