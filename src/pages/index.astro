---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Dave Digital Creative</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: #050505;
        color: white;
        font-family: Inter, sans-serif;
      }

      a {
        color: inherit;
      }

      .hero {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
      }

      .hero video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.24;
      }

      .hero::after {
        content: "";
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at center, rgba(255, 255, 255, 0.08), transparent 35%),
          linear-gradient(to bottom, rgba(0, 0, 0, 0.35), rgba(5, 5, 5, 0.98));
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 1060px;
        padding: 2rem;
        margin: 0 auto;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 1rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #d0d0d0;
      }

      h1 {
        margin: 0 0 1.5rem;
        font-size: clamp(3rem, 7vw, 6.8rem);
        line-height: 0.92;
        letter-spacing: -0.07em;
        text-align: center;
      }

      .hero p {
        max-width: 760px;
        margin: 0 auto;
        color: #d0d0d0;
        font-size: clamp(1.05rem, 2vw, 1.3rem);
        line-height: 1.7;
        text-align: center;
      }

      .buttons {
        margin-top: 2.4rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .button {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 800;
        transition: 0.25s ease;
      }

      .primary {
        background: white;
        color: black;
      }

      .secondary {
        border: 1px solid #444;
        background: rgba(255, 255, 255, 0.04);
      }

      .button:hover {
        transform: translateY(-3px);
      }

      .section {
        width: min(1180px, calc(100% - 2rem));
        margin: auto;
        padding: 6rem 0;
      }

      .section-header {
        max-width: 850px;
        margin: 0 auto 3rem;
        text-align: center;
      }

      h2 {
        margin: 0 0 1rem;
        font-size: clamp(2.35rem, 5vw, 4.1rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
        text-align: center;
      }

      .section-header p {
        max-width: 760px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.7;
        font-size: 1.08rem;
        text-align: center;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 1.15rem;
      }

      .card {
        background: linear-gradient(180deg, #121212, #0c0c0c);
        border: 1px solid #222;
        border-radius: 24px;
        padding: 1.65rem;
        transition: 0.25s ease;
        text-align: center;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: #555;
      }

      .card h3 {
        margin: 0 0 0.75rem;
        font-size: 1.25rem;
        text-align: center;
      }

      .card p {
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.65;
        font-size: 0.98rem;
        text-align: center;
      }

      .media-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 1.25rem;
      }

      .media-card {
        grid-column: span 6;
        overflow: hidden;
        background: linear-gradient(180deg, #121212, #0b0b0b);
        border-radius: 24px;
        border: 1px solid #222;
      }

      .media-card.large {
        grid-column: span 12;
      }

      .media-card img,
      .media-card video {
        width: 100%;
        height: 260px;
        display: block;
        object-fit: cover;
        background: #090909;
      }

      .media-card.large video {
        height: 420px;
      }

      .media-copy {
        padding: 1.35rem;
        text-align: center;
      }

      .media-copy h3 {
        margin: 0 0 0.55rem;
        font-size: 1.28rem;
        text-align: center;
      }

      .media-copy p {
        max-width: 680px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.65;
        font-size: 0.98rem;
        text-align: center;
      }

      .pricing {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(285px, 1fr));
        gap: 1.25rem;
      }

      .price-card {
        background: linear-gradient(180deg, #121212, #0b0b0b);
        border: 1px solid #222;
        border-radius: 24px;
        padding: 1.75rem;
        text-align: center;
      }

      .price-card h3 {
        margin: 0;
        font-size: 1.45rem;
        text-align: center;
      }

      .price {
        margin: 0.8rem 0 1rem;
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
        text-align: center;
      }

      .price-card ul {
        display: inline-block;
        margin: 0 auto;
        padding-left: 1.2rem;
        color: #bdbdbd;
        line-height: 1.85;
        text-align: left;
      }

      .contact {
        text-align: center;
        padding-bottom: 7rem;
      }

      .contact-links {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .contact-links a {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        border: 1px solid #333;
        text-decoration: none;
        font-weight: 700;
        transition: 0.25s ease;
      }

      .contact-links a:hover {
        transform: translateY(-3px);
        border-color: #777;
      }

      @media (max-width: 780px) {
        .section {
          padding: 4.75rem 0;
        }

        .media-card,
        .media-card.large {
          grid-column: span 12;
        }

        .media-card img,
        .media-card video,
        .media-card.large video {
          height: 240px;
        }
      }
    </style>
  </head>

  <body>
    <section class="hero">
      <video autoplay muted loop playsinline>
        <source src="/videos/reel.mp4" type="video/mp4" />
      </video>

      <div class="hero-content">
        <div class="eyebrow">Creator Media Systems</div>

        <h1>AI-Powered Media Systems for Creators</h1>

        <p>
          Promo campaigns, creator branding, livestream systems, cinematic AI
          visuals, sonic branding, and media infrastructure for modern creator
          brands.
        </p>

        <div class="buttons">
          <a href="#work" class="button primary">View Work</a>
          <a href="#contact" class="button secondary">Contact</a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>What I Build</h2>

        <p>
          Creator-focused media assets and systems built for livestreams,
          educational brands, podcasts, creator communities, and online media
          ecosystems.
        </p>
      </div>

      <div class="grid">
        <div class="card">
          <h3>AI Promo Campaigns</h3>
          <p>
            Cinematic creator promos, livestream intros, sponsor ads, launch
            campaigns, and short-form promotional systems.
          </p>
        </div>

        <div class="card">
          <h3>Sonic Branding</h3>
          <p>
            Creator songs, recurring music identity, meme tracks, and branded
            intro systems.
          </p>
        </div>

        <div class="card">
          <h3>Livestream Systems</h3>
          <p>
            Dashboards, overlays, layouts, and visual infrastructure for live
            creators.
          </p>
        </div>

        <div class="card">
          <h3>NotebookLM Cinematics</h3>
          <p>
            Research-backed cinematic AI workflows, educational systems, and
            structured media prep.
          </p>
        </div>
      </div>
    </section>

    <section id="work" class="section">
      <div class="section-header">
        <h2>Featured Work</h2>

        <p>
          Real creator systems developed across active channels, livestreams,
          creator brands, and AI-assisted media ecosystems.
        </p>
      </div>

      <div class="media-grid">
        <div class="media-card large">
          <video controls playsinline>
            <source src="/videos/promo-bgt.mp4" type="video/mp4" />
          </video>

          <div class="media-copy">
            <h3>Creator Promo Systems</h3>
            <p>
              Cinematic promotional assets built for livestreams, creator
              brands, and community engagement.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/dashboard.png" alt="Livestream dashboard" />

          <div class="media-copy">
            <h3>Livestream Dashboard</h3>
            <p>
              Real-world broadcast dashboard system used for recurring
              livestream production.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/sonic-branding.png" alt="Sonic branding assets" />

          <div class="media-copy">
            <h3>Sonic Branding</h3>
            <p>
              15+ custom songs deployed across multiple channels, shows, and
              creator ecosystems.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/notebooklm.png" alt="NotebookLM cinematic workflow" />

          <div class="media-copy">
            <h3>NotebookLM Cinematics</h3>
            <p>
              AI-assisted cinematic educational systems built from structured
              research workflows.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/mascot.png" alt="Mascot and identity system" />

          <div class="media-copy">
            <h3>Mascots & Identity Systems</h3>
            <p>
              Recurring creator visuals, characters, and ecosystem branding.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/banners.png" alt="Banners and visual systems" />

          <div class="media-copy">
            <h3>Banners & Visual Systems</h3>
            <p>
              Creator branding assets, overlays, banners, and visual identity
              packages.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>Packages</h2>

        <p>
          Flexible creator-focused packages built around branding, promotional
          systems, and media infrastructure.
        </p>
      </div>

      <div class="pricing">
        <div class="price-card">
          <h3>Promo Campaigns</h3>

          <div class="price">$500+</div>

          <ul>
            <li>15s and 30s promos</li>
            <li>2–4 minute cinematic promos</li>
            <li>Livestream intros</li>
            <li>Sponsor creatives</li>
            <li>Paid promotion assets</li>
          </ul>
        </div>

        <div class="price-card">
          <h3>Creator Branding</h3>

          <div class="price">$1,200+</div>

          <ul>
            <li>Overlays and banners</li>
            <li>Mascots and logos</li>
            <li>Visual identity systems</li>
            <li>Sonic branding</li>
            <li>Brand ecosystem direction</li>
          </ul>
        </div>

        <div class="price-card">
          <h3>Media Systems</h3>

          <div class="price">$1,500+</div>

          <ul>
            <li>NotebookLM workflows</li>
            <li>Research systems</li>
            <li>Dashboard systems</li>
            <li>Content pipelines</li>
            <li>Educational media structuring</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="contact" class="section contact">
      <div class="section-header">
        <h2>Let’s Build Something</h2>

        <p>
          Interested in creator promos, cinematic media assets, livestream
          systems, or AI-powered creator infrastructure?
        </p>
      </div>

      <div class="contact-links">
        <a href="https://x.com/_davedigital" target="_blank">X / Twitter</a>

        <a href="mailto:djdjfrosty@gmail.com">Email</a>

        <a href="https://www.youtube.com/@BillyGoatTales" target="_blank">
          BillyGoatTales
        </a>
      </div>
    </section>
  </body>
</html>