---
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Dave Digital Creative</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <style>
      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: #050505;
        color: white;
        font-family: Inter, sans-serif;
      }

      a {
        color: inherit;
      }

      .hero,
      .section {
        width: min(1180px, calc(100% - 2rem));
        margin: auto;
      }

      .hero {
        padding: 5rem 0 3rem;
        text-align: center;
      }

      .eyebrow {
        display: inline-flex;
        margin-bottom: 1rem;
        padding: 0.55rem 0.9rem;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        background: rgba(255, 255, 255, 0.05);
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #d0d0d0;
      }

      h1 {
        margin: 0 0 1.5rem;
        font-size: clamp(3rem, 7vw, 6.8rem);
        line-height: 0.92;
        letter-spacing: -0.07em;
        text-align: center;
      }

      .hero p {
        max-width: 760px;
        margin: 0 auto;
        color: #d0d0d0;
        font-size: clamp(1.05rem, 2vw, 1.3rem);
        line-height: 1.7;
        text-align: center;
      }

      .hero-videos {
        margin-top: 3rem;
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }

      .video-card,
      .card,
      .price-card,
      .media-card {
        background: linear-gradient(180deg, #121212, #0b0b0b);
        border: 1px solid #222;
        border-radius: 24px;
        overflow: hidden;
      }

      .video-card video,
      .media-card video,
      .media-card img {
        width: 100%;
        height: 320px;
        display: block;
        object-fit: cover;
        background: #090909;
      }

      .video-copy,
      .media-copy {
        padding: 1.25rem;
        text-align: center;
      }

      .video-copy h3,
      .media-copy h3 {
        margin: 0 0 0.45rem;
        font-size: 1.2rem;
      }

      .video-copy p,
      .media-copy p {
        max-width: 620px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .buttons {
        margin-top: 2.4rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .button {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 800;
        transition: 0.25s ease;
      }

      .primary {
        background: white;
        color: black;
      }

      .secondary {
        border: 1px solid #444;
        background: rgba(255, 255, 255, 0.04);
      }

      .button:hover,
      .card:hover,
      .price-card:hover,
      .video-card:hover,
      .media-card:hover {
        transform: translateY(-3px);
        border-color: #555;
      }

      .card,
      .price-card,
      .video-card,
      .media-card {
        transition: 0.25s ease;
      }

      .section {
        padding: 6rem 0;
      }

      .section-header {
        max-width: 850px;
        margin: 0 auto 3rem;
        text-align: center;
      }

      h2 {
        margin: 0 0 1rem;
        font-size: clamp(2.35rem, 5vw, 4.1rem);
        line-height: 0.98;
        letter-spacing: -0.06em;
        text-align: center;
      }

      .section-header p {
        max-width: 760px;
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.7;
        font-size: 1.08rem;
        text-align: center;
      }

      .spec-grid,
      .pricing,
      .grid {
        display: grid;
        gap: 1.25rem;
      }

      .spec-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .grid {
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      }

      .pricing {
        grid-template-columns: repeat(auto-fit, minmax(285px, 1fr));
      }

      .card {
        padding: 1.65rem;
        text-align: center;
      }

      .card h3 {
        margin: 0 0 0.75rem;
        font-size: 1.25rem;
      }

      .card p {
        margin: 0 auto;
        color: #a8a8a8;
        line-height: 1.65;
        font-size: 0.98rem;
      }

      .price-card {
        position: relative;
        padding: 1.75rem;
        text-align: center;
      }

      .popular {
        border-color: #666;
        transform: scale(1.02);
      }

      .popular-badge {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: white;
        color: black;
        padding: 0.4rem 0.7rem;
        border-radius: 999px;
        font-size: 0.75rem;
        font-weight: 800;
      }

      .price-card h3 {
        margin: 0;
        font-size: 1.45rem;
      }

      .price {
        margin: 0.8rem 0 1rem;
        font-size: 2.25rem;
        font-weight: 900;
        letter-spacing: -0.05em;
      }

      .price-card ul {
        display: inline-block;
        margin: 0 auto;
        padding-left: 1.2rem;
        color: #bdbdbd;
        line-height: 1.85;
        text-align: left;
      }

      .media-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.25rem;
      }

      .contact {
        text-align: center;
        padding-bottom: 7rem;
      }

      .contact-links {
        margin-top: 2rem;
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .contact-links a {
        padding: 0.95rem 1.45rem;
        border-radius: 999px;
        border: 1px solid #333;
        text-decoration: none;
        font-weight: 700;
        transition: 0.25s ease;
      }

      .contact-links a:hover {
        transform: translateY(-3px);
        border-color: #777;
      }

      footer {
        border-top: 1px solid #1a1a1a;
        padding: 2rem;
        text-align: center;
        color: #666;
        font-size: 0.9rem;
      }

      @media (max-width: 900px) {
        .hero-videos,
        .spec-grid,
        .media-grid {
          grid-template-columns: 1fr;
        }

        .video-card video,
        .media-card video,
        .media-card img {
          height: 260px;
        }

        .popular {
          transform: none;
        }
      }

      @media (max-width: 520px) {
        .hero {
          padding: 3.5rem 0 2rem;
        }

        .section {
          padding: 4.75rem 0;
        }

        .video-card video,
        .media-card video,
        .media-card img {
          height: 230px;
        }
      }
    </style>
  </head>

  <body>
    <section class="hero">
      <div class="eyebrow">Cinematic AI Commercial Creative</div>

      <h1>AI Video Commercials for Brands</h1>

      <p>
        Monthly retainer-based cinematic ad creative for businesses running
        paid social. Fresh 15–30 second video spots every month — no production
        team required.
      </p>

      <div class="hero-videos">
        <div class="video-card">
          <video autoplay muted loop playsinline controls>
            <source src="/videos/milk-honey-spec.mp4" type="video/mp4" />
          </video>

          <div class="video-copy">
            <h3>Milk + Honey Spa — Spec Ad</h3>
            <p>Custom cinematic spec ad built for Milk + Honey Houston.</p>
          </div>
        </div>

        <div class="video-card">
          <video autoplay muted loop playsinline controls>
            <source src="/videos/skinspirit-spec.mp4" type="video/mp4" />
          </video>

          <div class="video-copy">
            <h3>SkinSpirit — Spec Ad</h3>
            <p>Custom cinematic spec ad built for SkinSpirit Rice Village.</p>
          </div>
        </div>
      </div>

      <div class="buttons">
        <a href="#contact" class="button primary">
          Want To See What We'd Make For Your Brand?
        </a>

        <a href="#pricing" class="button secondary">
          View Monthly Options
        </a>
      </div>
    </section>

    <section class="section" id="spec-ads">
      <div class="section-header">
        <h2>More Spec Ads</h2>
        <p>
          A growing proof-of-work library of short cinematic ad concepts built
          for real Houston-area businesses.
        </p>
      </div>

      <div class="spec-grid">
        <div class="video-card">
          <video autoplay muted loop playsinline controls>
            <source src="/videos/dermatouch-spec.mp4" type="video/mp4" />
          </video>

          <div class="video-copy">
            <h3>DermaTouch RN — Spec Ad</h3>
            <p>Custom cinematic spec ad built for a Houston skincare brand.</p>
          </div>
        </div>

        <div class="video-card">
          <video autoplay muted loop playsinline controls>
            <source src="/videos/dream-aesthetics-spec.mp4" type="video/mp4" />
          </video>

          <div class="video-copy">
            <h3>Dream Aesthetics — Spec Ad</h3>
            <p>Short-form cinematic ad creative for an aesthetics brand.</p>
          </div>
        </div>

        <div class="video-card">
          <video autoplay muted loop playsinline controls>
            <source src="/videos/galleria-aesthetics-spec.mp4" type="video/mp4" />
          </video>

          <div class="video-copy">
            <h3>Galleria Aesthetics — Spec Ad</h3>
            <p>AI-powered commercial concept for a local aesthetics business.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-header">
        <h2>What I Build</h2>

        <p>
          Cinematic AI commercial creative for brands running paid social ads
          across Facebook, Instagram, YouTube, and short-form platforms.
        </p>
      </div>

      <div class="grid">
        <div class="card">
          <h3>AI Video Commercials</h3>
          <p>
            Monthly ad creative for businesses running Facebook, Instagram, and
            YouTube ads. Fresh 15s and 30s cinematic spots — custom to your
            brand, delivered monthly.
          </p>
        </div>

        <div class="card">
          <h3>Spec Ad Previews</h3>
          <p>
            Not sure what you'd get? I build a real short spec ad for your brand
            before you commit to anything. See the work first.
          </p>
        </div>

        <div class="card">
          <h3>Sonic Branding</h3>
          <p>
            Custom music and sound identity for brands that want a complete
            audio-visual package.
          </p>
        </div>
      </div>
    </section>

    <section id="pricing" class="section">
      <div class="section-header">
        <h2>Monthly Retainers</h2>

        <p>
          Built for businesses already spending on ads that need fresh creative
          every month without hiring a production team.
        </p>
      </div>

      <div class="pricing">
        <div class="price-card">
          <h3>Starter</h3>
          <div class="price">$1,000/mo</div>

          <ul>
            <li>2 fresh video ads per month</li>
            <li>15s + 30s formats</li>
            <li>1 revision round each</li>
            <li>Music included</li>
            <li>Delivered by the 10th</li>
            <li>Month-to-month</li>
          </ul>
        </div>

        <div class="price-card popular">
          <div class="popular-badge">Most Popular</div>

          <h3>Growth</h3>
          <div class="price">$2,500/mo</div>

          <ul>
            <li>4 ads per month</li>
            <li>Weekly delivery cadence</li>
            <li>15s, 30s, and social cuts</li>
            <li>2 revision rounds each</li>
            <li>Priority 48-hour turnaround</li>
            <li>Sonic branding included</li>
            <li>Month-to-month</li>
          </ul>
        </div>

        <div class="price-card">
          <h3>Full System</h3>
          <div class="price">$5,000/mo</div>

          <ul>
            <li>Weekly content + strategy</li>
            <li>Full ad creative suite</li>
            <li>Sonic branding identity</li>
            <li>Monthly planning session</li>
            <li>Unlimited minor revisions</li>
            <li>Month-to-month</li>
          </ul>
        </div>
      </div>
    </section>

    <section id="work" class="section">
      <div class="section-header">
        <h2>Additional Work</h2>

        <p>
          Supporting creative systems, branded media assets, and audio-visual
          identity work built across creator and business ecosystems.
        </p>
      </div>

      <div class="media-grid">
        <div class="media-card">
          <img src="/images/dashboard.png" alt="Visual systems" />

          <div class="media-copy">
            <h3>Visual Systems</h3>
            <p>
              Supporting portfolio work showcasing branded visual systems,
              recurring production layouts, and organized presentation flow.
            </p>
          </div>
        </div>

        <div class="media-card">
          <img src="/images/sonic-branding.png" alt="Sonic branding assets" />

          <div class="media-copy">
            <h3>Sonic Branding</h3>
            <p>
              Custom songs, branded sound identity, and recurring audio systems
              developed across multiple creator and business ecosystems.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section id="contact" class="section contact">
      <div class="section-header">
        <h2>Want To See What We'd Make For Your Brand?</h2>

        <p>
          Running paid social and want fresh video creative every month without
          hiring a production team? Let's talk.
        </p>
      </div>

      <div class="contact-links">
        <a href="https://x.com/_davedigital" target="_blank">X / Twitter</a>
        <a href="https://instagram.com/_davedigital" target="_blank">
          Instagram
        </a>
        <a href="mailto:djdjfrosty@gmail.com">Email</a>
      </div>
    </section>

    <footer>
      Additional creative and creator ecosystem work available upon request.
    </footer>
  </body>
</html>